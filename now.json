{
  "version": 2,
  "name": "morganatwork",
  "alias": ["www.morganatwork.com"],
  "build": {
    "env": {
      "NPM_TOKEN": "@npm-token"
    }
  },
  "builds": [
    {
      "src": "main/next.config.js",
      "use": "@now/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/main/$1"
    }
  ]
}