{
  "version": 2,
  "name": "morganatwork",
  "alias": ["www.morganatwork.com"],
  "public": true,
  "env": {
    "CODA_TOKEN": "@coda-token"
  },
  "build": {
    "env": {
      "NODE_ENV": "production",
      "CODA_TOKEN": "@coda-token"
    }
  },
  "builds": [
    {
      "src": "app/package.json",
      "use": "@now/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app/$1"
    }
  ]
}
